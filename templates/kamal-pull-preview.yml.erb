# Copy this to your project root as kamal-pull-preview.yml

# SSH host where preview containers will be deployed (required).
# This must be reachable by the machine running kamal-pull-preview.
host: "preview.example.com"

# Base domain for preview URLs (required).
# Each PR will get a subdomain like pr-42.preview.example.com.
domain: "preview.example.com"

# Docker registry prefix used by Kamal (required).
# Must match the "image" setting in your config/deploy.yml.
registry: "registry.example.com/myorg/myapp"

# How many hours before an inactive preview is considered expired.
# Default: 48
ttl_hours: 48

# Minutes of inactivity before the container is automatically stopped.
# Default: 240 (4 hours)
idle_stop_minutes: 240

# Maximum number of concurrently running previews.
# Attempting to deploy beyond this limit raises an error.
# Default: 15
max_concurrent: 15

# Database strategy for preview environments.
# Options:
#   "none"          — no database, stateless app or app handles its own DB
#   "sqlite"        — each preview gets its own SQLite file (volume-mounted)
#   "shared_schema" — previews share a Postgres DB with schema-per-PR isolation
# Default: "none"
db_strategy: "none"
